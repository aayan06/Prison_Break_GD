ection"},{"propertyName":"MaxOpacity"}]}}],"eventsBasedObjects":[]},{"author":"Tristan Rhodes (https://victrisgames.itch.io/)","category":"Movement","dimension":"2D","extensionNamespace":"","fullName":"Homing projectile","gdevelopVersion":">=5.5.222","helpPath":"https://victrisgames.itch.io/extension-homing-projectile","iconUrl":"data:image/svg+xml;base64,","name":"HomingProjectile","previewIconUrl":"https://resources.gdevelop-app.com/assets/Icons/rocket-launch.svg","shortDescription":"Make a projectile object move towards a target object.","version":"0.2.0","description":["This extension requires two actions to function correctly:","1) \"Lock projectile to target\" should be used once per projectile. ","2) \"Move projectile towards target\" should be run every frame.  This will move all projectiles that are locked to targets.","","Parameters:","- Rotation Speed: How fast the projectile rotates. This is critical in determining how fast the projectile can turn corners.","- Initial Speed: Starting speed of the projectile","- Acceleration: How much speed is added over time","- Max Speed:  The max speed a projectile can travel (does not apply to physics object)","- Max Lifetime:  The number of seconds a projectile can exist after locking onto a target.  Once this time is reached the object is deleted.","","Tips:","- Make sure to set the angle of the projectile before you use the \"Move\" action.  The projectile will turn towards the target, but you might want the projectile to be facing a certain direction. ","- Since Max Speed is not enforced on the physics object, you can accomplish this by changing Linear Decay on the Physics behavior","- Use the lifetime parameter to prevent missiles from chasing objects forever"],"origin":{"identifier":"HomingProjectile","name":"gdevelop-extension-store"},"tags":["projectile","homing","target","guided","missile","rocket","autoattack","ranged","attack","fire","shoot"],"authorIds":["gqDaZjCfevOOxBYkK6zlhtZnXCg1"],"dependencies":[],"globalVariables":[],"sceneVariables":[],"eventsFunctions":[{"description":"Lock projectile object to target object.  (This is required for \"Move projectile towards target\").","fullName":"Lock projectile to target","functionType":"Action","name":"LockOnTarget","sentence":"Lock projectile _PARAM1_ to target _PARAM2_","events":[{"type":"BuiltinCommonInstructions::Standard","conditions":[],"actions":[{"type":{"value":"LinkedObjects::LinkObjects"},"parameters":["","ProjectileObject","TargetObject"]},{"type":{"value":"ResetObjectTimer"},"parameters":["ProjectileObject","\"__HomingProjectile_Lifetime\""]}]}],"parameters":[{"description":"Projectile object","name":"ProjectileObject","type":"objectList"},{"description":"Target object","name":"TargetObject","type":"objectList"}],"objectGroups":[]},{"description":"Move physics projectile towards the object that it has been locked to.  This action must be run every frame.","fullName":"Move physics projectile towards target","functionType":"Action","name":"MoveTowardsTargetPhysics","sentence":"Move physics projectile _PARAM1_ towards target _PARAM3_.  Rotate speed: _PARAM4_ Initial speed: _PARAM5_ Acceleration: _PARAM6_ Max Lifetime: _PARAM7_ Delete on collision: _PARAM8_","events":[{"type":"BuiltinCommonInstructions::ForEach","object":"ProjectileObject","conditions":[{"type":{"value":"LinkedObjects::PickObjectsLinkedTo"},"parameters":["","TargetObject","ProjectileObject"]}],"actions":[],"events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"Disable gravity on this object"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"Physics2::GravityScale"},"parameters":["ProjectileObject","PhysicsBehavior","!=","0"]}],"actions":[{"type":{"value":"Physics2::GravityScale"},"parameters":["ProjectileObject","PhysicsBehavior","=","0"]}]},{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"Stop rotation forces"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"Physics2::AngularVelocity"},"parameters":["ProjectileObject","PhysicsBehavior","!=","0"]}],"actions":[{"type":{"value":"Physics2::AngularVelocity"},"parameters":["ProjectileObject","PhysicsBehavior","=","0"]}]},{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"Rotate towards the target"},{"type":"BuiltinCommonInstructions::Standard","conditions":[],"actions":[{"type":{"value":"RotateTowardPosition"},"parameters":["ProjectileObject","TargetObject.CenterX()","TargetObject.CenterY()","RotationSpeed",""]}]},{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"Calculate the mass of the object"},{"type":"BuiltinCommonInstructions::Standard","conditions":[],"actions":[{"type":{"value":"ModVarObjet"},"parameters":["ProjectileObject","__HomingProjectile.Mass","=","ProjectileObject.PhysicsBehavior::Density() * ProjectileObject.Width() * ProjectileObject.Height()"]}]},{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"Set initial speed (making sure not to divide by 0)"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"ObjectVariableAsBoolean"},"parameters":["ProjectileObject","__HomingProjectile.InitialBoostCompleted","False"]},{"type":{"value":"VarObjet"},"parameters":["ProjectileObject","__HomingProjectile.Mass","!=","0"]}],"actions":[{"type":{"value":"Physics2::ApplyPolarImpulse"},"parameters":["ProjectileObject","PhysicsBehavior","ProjectileObject.Angle()","10 * InitialSpeed / ProjectileObject.Variable(__HomingProjectile.Mass)","ProjectileObject.CenterX()","ProjectileObject.CenterY()"]},{"type":{"value":"SetObjectVariableAsBoolean"},"parameters":["ProjectileObject","__HomingProjectile.InitialBoostCompleted","True"]}]},{"type":"