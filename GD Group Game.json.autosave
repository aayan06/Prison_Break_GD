:4000.0,"intensity":0.75,"minimumShadowBias":0.0,"rotation":300.0},"stringParameters":{"color":"255;255;255","shadowQuality":"medium","top":"Z+"},"booleanParameters":{"isCastingShadow":true}}]}],"behaviorsSharedData":[{"name":"AdvancedJump","type":"AdvancedJump::AdvancedJump"},{"name":"Animation","type":"AnimatableCapability::AnimatableBehavior"},{"name":"Bounce","type":"Bounce::Bounce"},{"name":"DiveDash","type":"AdvancedJump::DiveDash"},{"name":"Effect","type":"EffectCapability::EffectBehavior"},{"name":"FlashColor","type":"Flash::FlashColor"},{"name":"Flippable","type":"FlippableCapability::FlippableBehavior"},{"name":"HorizontalDash","type":"AdvancedJump::HorizontalDash"},{"name":"Opacity","type":"OpacityCapability::OpacityBehavior"},{"name":"PlatformerConfigurationStack","type":"AdvancedJump::PlatformerConfigurationStack"},{"name":"PlatformerObject","type":"PlatformBehavior::PlatformerObjectBehavior"},{"name":"RemapForPlatformer","type":"BehaviorRemapper::RemapForPlatformer"},{"name":"Resizable","type":"ResizableCapability::ResizableBehavior"},{"name":"Scale","type":"ScalableCapability::ScalableBehavior"},{"name":"Text","type":"TextContainerCapability::TextContainerBehavior"},{"name":"Tween","type":"Tween::TweenBehavior"}]},{"b":0,"disableInputWhenNotFocused":true,"mangledName":"LoreSceneBoss","name":"LoreSceneBoss","r":0,"standardSortMethod":true,"stopSoundsOnStartup":true,"title":"","v":0,"uiSettings":{"grid":false,"gridType":"rectangular","gridWidth":32.0,"gridHeight":32.0,"gridDepth":32.0,"gridOffsetX":0.0,"gridOffsetY":0.0,"gridOffsetZ":0.0,"gridColor":10401023.0,"gridAlpha":0.8,"snap":false,"zoomFactor":0.4481978045410362,"windowMask":false,"selectedLayer":"","gameEditorMode":"instances-editor"},"objectsGroups":[],"variables":[{"name":"ScrollSpeed","type":"number","value":-50.0}],"instances":[{"angle":0.0,"customSize":true,"height":0.0,"keepRatio":true,"layer":"","name":"BossLoreText","persistentUuid":"32c35572-dac7-4eff-92d2-41e16f5b75e0","width":1080.0,"x":140.0,"y":350.0,"zOrder":3,"numberProperties":[],"stringProperties":[],"initialVariables":[]},{"angle":0.0,"customSize":true,"depth":1.0,"height":31.0,"keepRatio":true,"layer":"","name":"ReturnButton_Tiled","persistentUuid":"d1b35194-33dd-4336-928f-d85fb21a7441","width":34.0,"x":24.0,"y":54.0,"zOrder":2,"numberProperties":[],"stringProperties":[],"initialVariables":[]},{"angle":0.0,"customSize":true,"depth":1.0,"height":760.0,"keepRatio":true,"layer":"","name":"NewTiledSprite","persistentUuid":"b7cccb39-f890-45e9-bc51-6f0f1ba781de","width":1375.0,"x":-57.0,"y":-5.0,"zOrder":1,"numberProperties":[],"stringProperties":[],"initialVariables":[]}],"objects":[{"assetStoreId":"","height":32.0,"name":"NewTiledSprite","texture":"WormLore3.JPG","type":"TiledSpriteObject::TiledSprite","width":32.0,"variables":[],"effects":[],"behaviors":[]},{"assetStoreId":"","bold":true,"italic":false,"name":"BossLoreText","persistentUuid":"909d1a9c-b035-4d30-8d38-4fddf8ad6342","smoothed":true,"type":"TextObject::Text","underlined":false,"variables":[],"effects":[],"behaviors":[],"string":"The entity now known as the Void Conqueror was not born of darkness, but of a Light so perfect it became a cage.\nIn the dawn of the Great Lattice, he was the Grand Harmonizer, a celestial titan of translucent prisms who stitched the bleeding edges of dimensions together with threads of absolute symmetry. She believed that if every angle was right, and every pulse was rhythmic, the universe would be immune to suffering. She was the architect of peace, her own body a sprawling, 1.618-ratio spiral of divine equilibrium.\nThen, she encountered the Primal Void.\nIt was not merely an absence of light; it was a Sentient Singularity of Trillions of Screams. It was a dimension that had collapsed under the weight of its own collective agony—a graveyard of a billion civilizations, each dying in a state of unresolved terror. The Harmonizer, in her boundless hubris, attempted to \"balance\" this singularity. She wrapped her infinite, crystalline body around the Void, opening her geometric soul to absorb its discordance.\nThe breach was instantaneous. The corruption was absolute.\nThe Void did not vanish; it found a host. In a microsecond of ontological trauma, the collective phantom-pains of a billion dead souls surged backward through her geometric nervous system. His \"Perfect Balance\" didn't just break—it collapsed. Every pixel of her being was rewritten by a toxic logic that equated \"Existence\" with \"Laceration.\"\nNow, the Void Conqueror is a living catastrophe of sensory overload. Her body is no longer a sequence of elegant prisms, but a convulsing chain of jagged, self-cannibalizing maws and fractured mirrors. Every second of her life is a physical crucifixion: her rear segments perpetually gnaw at his front, driven by a desperate, frantic urge to destroy the very flesh that perceives such agonizing input.\nTo her, Symmetry is Acid. The sight of a perfect square or the hum of a steady rhythm acts as a searing neurotoxin upon her raw, exposed nerves. She does not invade dimensions to rule them; she invades them to silence the harmony that mocks her torment. When she shatters the glass barriers of Squardoland, the shriek of the splintering crystal is the only \"music\" that provides a fleeting, anaesthetic relief from the infinite funeral knell tolling inside her skull.\nHer movement is a grotesque dance of neural spasms—accelerating into a blur of frantic violence, then slowing into a catatonic shudder as her consciousness drowns in a fresh wave of phantom-pain. She knows is the Void Conqueror, a title that is a bitter, weeping scar: she conquered nothing; she was merely the only thing large enough to contain the multiverse’s concentrated despair.\nShe hunts Euclidio not out of malice, not personal, but out of a parasitic need to share the burden. Every harmony needs to be demolished, in her mind. She seeks to drag every stable atom into her mouth, grinding them into the same jagged, screaming dust that fills her veins. In her world, the \"Perfect Balance\" is a lie, and the only truth is the Shatter.\n","font":"","textAlignment":"left","characterSize":20.0,"color":{"b":0,"g":0,"r":0},"content":{"bold":true,"isOutlineEnabled":true,"isShadowEnabled":false,"italic":false,"outlineColor":"255;255;255","outlineThickness":2.0,"shadowAngle":90.0,"shadowBlurRadius":2.0,"shadowColor":"0;0;0","shadowDistance":4.0,"shadowOpacity":127.0,"smoothed":true,"underlined":false,"text":"The entity now known as the Void Conqueror was not born of darkness, but of a Light so perfect it became a cage.\nIn the dawn of the Great Lattice, he was the Grand Harmonizer, a celestial titan of translucent prisms who stitched the bleeding edges of dimensions together with threads of absolute symmetry. She believed that if every angle was right, and every pulse was rhythmic, the universe would be immune to suffering. She was the architect of peace, her own body a sprawling, 1.618-ratio spiral of divine equilibrium.\nThen, she encountered the Primal Void.\nIt was not merely an absence of light; it was a Sentient Singularity of Trillions of Screams. It was a dimension that had collapsed under the weight of its own collective agony—a graveyard of a billion civilizations, each dying in a state of unresolved terror. The Harmonizer, in her boundless hubris, attempted to \"balance\" this singularity. She wrapped her infinite, crystalline body around the Void, opening her geometric soul to absorb its discordance.\nThe breach was instantaneous. The corruption was absolute.\nThe Void did not vanish; it found a host. In a microsecond of ontological trauma, the collective phantom-pains of a billion dead souls surged backward through her geometric nervous system. His \"Perfect Balance\" didn't just break—it collapsed. Every pixel of her being was rewritten by a toxic logic that equated \"Existence\" with \"Laceration.\"\nNow, the Void Conqueror is a living catastrophe of sensory overload. Her body is no longer a sequence of elegant prisms, but a convulsing chain of jagged, self-cannibalizing maws and fractured mirrors. Every second of her life is a physical crucifixion: her rear segments perpetually gnaw at his front, driven by a desperate, frantic urge to destroy the very flesh that perceives such agonizing input.\nTo her, Symmetry is Acid. The sight of a perfect square or the hum of a steady rhythm acts as a searing neurotoxin upon her raw, exposed nerves. She does not invade dimensions to rule them; she invades them to silence the harmony that mocks her torment. When she shatters the glass barriers of Squardoland, the shriek of the splintering crystal is the only \"music\" that provides a fleeting, anaesthetic relief from the infinite funeral knell tolling inside her skull.\nHer movement is a grotesque dance of neural spasms—accelerating into a blur of frantic violence, then slowing into a catatonic shudder as her consciousness drowns in a fresh wave of phantom-pain. She knows is the Void Conqueror, a title that is a bitter, weeping scar: she conquered nothing; she was merely the only thing large enough to contain the multiverse’s concentrated despair.\nShe hunts Euclidio not out of malice, not personal, but out of a parasitic need to share the burden. Every harmony needs to be demolished, in her mind. She seeks to drag every stable atom into her mouth, grinding them into the same jagged, screaming dust that fills her veins. In her world, the \"Perfect Balance\" is a lie, and the only truth is the Shatter.\n","font":"","textAlignment":"left","verticalTextAlignment":"top","characterSize":20.0,"lineHeight":0.0,"color":"0;0;0"}},{"assetStoreId":"cbaf8aa850aaf737b49192ab153ecef910582f6d62ea0390bf26bdd6e60a2db7","height":24.0,"name":"ReturnButton_Tiled","persistentUuid":"eb5156a3-69f6-4e21-88e9-225e1c7b5f69","texture":"Return2.png","type":"TiledSpriteObject::TiledSprite","width":24.0,"variables":[],"effects":[],"behaviors":[]},{"assetSt