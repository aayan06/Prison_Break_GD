,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"Delete object if a lifetime has been set and reached"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"Egal"},"parameters":["MaxLifetime","!=","0"]},{"type":{"value":"ObjectTimer"},"parameters":["ProjectileObject","\"__HomingProjectile_Lifetime\"","MaxLifetime"]}],"actions":[{"type":{"value":"Delete"},"parameters":["ProjectileObject",""]}]},{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"Delete if projectile touches target "},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"BooleanVariable"},"parameters":["DeleteOnCollision","True",""]},{"type":{"value":"CollisionNP"},"parameters":["ProjectileObject","TargetObject","","",""]}],"actions":[{"type":{"value":"Delete"},"parameters":["ProjectileObject",""]}]}]}],"parameters":[{"description":"Projectile object","name":"ProjectileObject","type":"objectList"},{"description":"Physics Behavior","name":"PhysicsBehavior","supplementaryInformation":"Physics2::Physics2Behavior","type":"behavior"},{"description":"Target object","name":"TargetObject","type":"objectList"},{"description":"Rotation speed (degrees per second)","name":"RotationSpeed","type":"expression"},{"description":"Initial speed (pixels per second)","name":"InitialSpeed","type":"expression"},{"description":"Acceleration (speed increase per second)","name":"Acceleration","type":"expression"},{"description":"Max lifetime (seconds)","longDescription":"Projectile will be deleted after this value is reached.","name":"MaxLifetime","type":"expression"},{"description":"Delete Projectile if it collides with Target:","name":"DeleteOnCollision","type":"yesorno"}],"objectGroups":[]},{"description":"Move projectile towards the object that it has been locked to.  This action must be run every frame.","fullName":"Move projectile towards target","functionType":"Action","name":"MoveTowardsTarget"